# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# UPI Payment
NEXT_PUBLIC_UPI_ID=your-upi-id
NEXT_PUBLIC_DEV_MODE=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GoldMine Pro

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=GLDMNE

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

# Mining Config
MINING_INTERVAL_HOURS=1
BASE_MINING_RATE=1.99

# Withdrawal
WITHDRAWAL_DATE=daily
WITHDRAWAL_WINDOW_DAYS=30
NEXT_PUBLIC_WITHDRAWAL_DATE=daily
MIN_WITHDRAWAL_AMOUNT=500

# Cron Secret
CRON_SECRET=your-cron-secret-key
USE_GOOGLE_DNS=true
